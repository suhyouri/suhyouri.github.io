<script>
  // ── CREATURE BLINK ──
  const frames = [
    document.getElementById('cf1'),
    document.getElementById('cf2'),
    document.getElementById('cf3')
  ];

  function showFrame(i) {
    frames.forEach((f, idx) => f.classList.toggle('visible', idx === i));
  }

  function blink() {
    // blink sequence: open → half → closed → half → open
    showFrame(0);
    setTimeout(() => showFrame(1), 0);
    setTimeout(() => showFrame(2), 60);
    setTimeout(() => showFrame(1), 130);
    setTimeout(() => showFrame(0), 190);
  }

  // random blink every 2–6 seconds
  function scheduleBlink() {
    const delay = 2000 + Math.random() * 4000;
    setTimeout(() => {
      blink();
      scheduleBlink();
    }, delay);
  }
  scheduleBlink();

  // ── NAV ──
  function showSection(id) {
    document.querySelectorAll('section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('nav a[data-section]').forEach(a => a.classList.remove('active'));
    const sec = document.getElementById(id);
    if (sec) sec.classList.add('active');
    const link = document.querySelector(`nav a[data-section="${id}"]`);
    if (link) link.classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    return false;
  }

  document.querySelectorAll('nav a').forEach(a => {
    a.addEventListener('click', e => e.preventDefault());
  });

  // ── LANG TOGGLE ──
  let lang = 'en';
  function toggleLang() {
    lang = lang === 'en' ? 'kr' : 'en';
    document.querySelectorAll('.statement.en, .wml-intro.en, .project-desc.en').forEach(el => el.classList.toggle('hidden', lang === 'kr'));
    document.querySelectorAll('.statement.kr, .wml-intro.kr, .project-desc.kr').forEach(el => el.classList.toggle('hidden', lang === 'en'));
    document.querySelector('.lang-toggle').textContent = lang === 'en' ? 'EN / KR' : 'KR / EN';
  }

  // ── ARCHIVE FILTER ──
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      document.querySelectorAll('.archive-photo-item').forEach(item => {
        item.style.display = (filter === 'all' || item.dataset.cat === filter) ? '' : 'none';
      });
    });
  });

  // init
  document.querySelector('nav a[data-section="about"]').classList.add('active');
</script>
</body>
</html>